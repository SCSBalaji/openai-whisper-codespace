{
    "name": "Whisper Workspace",

    "build": {
        "dockerfile": "Dockerfile"
    },

    "postCreateCommand": "bash .devcontainer/setup.sh",

    "remoteEnv": {
        "RCLONE_CONFIG": "${localEnv:RCLONE_CONFIG}"
    },

    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance"
            ]
        }
    }
}